# Скопируй в .env и подставь свои значения. Секреты не коммить.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0

# Прод: IP или домен без порта (через запятую). Обязательно для доступа по http://IP:8001/
DJANGO_ALLOWED_HOSTS=zapier.diligentcrossbill.com.ru,localhost,127.0.0.1
# Для форм/логина: полный origin со схемой и портом
DJANGO_CSRF_TRUSTED_ORIGINS=https://zapier.diligentcrossbill.com.ru,http://zapier.diligentcrossbill.com.ru
SITE_DOMAIN=zapier.diligentcrossbill.com.ru
SITE_NAME=MiniZapier

POSTGRES_DB=minizapier
POSTGRES_USER=minizapier
POSTGRES_PASSWORD=change-me
# Локально без Docker: POSTGRES_HOST=localhost. В compose prod переопределяется на db.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0

MAIL_ENABLED=0
